{
  "name": "reveal-peerjs",
  "version": "1.4.0",
  "description": "Reveal.js plugin for real-time peer collaboration via PeerJS",
  "type": "module",
  "main": "dist/reveal-peerjs.js",
  "module": "dist/reveal-peerjs.es.js",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch --emptyOutDir=false",
    "preview": "node scripts/dev-server.js --no-watch",
    "dev-server": "node scripts/dev-server.js",
    "test-server": "node scripts/dev-server.js --no-watch",
    "test:e2e": "playwright test",
    "test:live-peerjs": "RPJS_LIVE_PEERJS=1 playwright test e2e/multiplayer.spec.js --grep 'Multiplayer - Hub and Visitors' --project=chromium --project=firefox",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "playwright test e2e/smoke.spec.js",
    "test:ui-audit": "node scripts/ui-audit.mjs",
    "check": "node scripts/check-source-syntax.js",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "reveal.js": "5.1.0",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "peerjs": "^1.5.4"
  },
  "license": "MIT"
}
